@startuml Health Center Class Diagram
left to right direction

!define LIGHTYELLOW #FFFACD
!define LIGHTBLUE #ADD8E6
!define LIGHTGREEN #90EE90
!define LIGHTPINK #FFB6C1
!define LIGHTCORAL #F08080

skinparam classAttributeIconSize 0
skinparam backgroundColor white
skinparam class {
    BackgroundColor<<User>> LIGHTBLUE
    BackgroundColor<<Service>> LIGHTGREEN
    BackgroundColor<<Data>> LIGHTYELLOW
    BackgroundColor<<App>> LIGHTPINK
    BackgroundColor<<Util>> LIGHTCORAL
}

' ========================================
' UTILITIES LAYER (LEFT SIDE)
' ========================================
package "Utilities" <<Util>> {
    together {
        class Validator {
            + {static} isNotEmpty(String): boolean
            + {static} isValidEmail(String): boolean
            + {static} isValidPhone(String): boolean
            + {static} isValidUsername(String): boolean
            + {static} isValidPassword(String): boolean
            + {static} isValidName(String): boolean
        }

        class LogManager {
            - String filePath
            + log(String, String): boolean
            + readLog(): ArrayList<String>
            + displayRecentLogs(int): void
        }

        class SystemInfo <<Serializable>> {
            - int executionCount
            - String lastUsername
            + incrementExecutionCount(): boolean
            + setLastUsername(String): boolean
        }

        class Colors {
            + {static} RESET: String
            + {static} BOLD_GREEN: String
            + {static} BOLD_YELLOW: String
            + {static} BOLD_CYAN: String
        }
    }
}

' ========================================
' USERS LAYER (TOP-LEFT)
' ========================================
package "Users Layer" <<User>> {
    together {
        class User <<Serializable>> {
            - String username
            - String email
            - String password
            - String name
            - String status
            - String type
            - boolean reviewed
            + verifyPassword(String): boolean
            + setEmail(String): boolean
            + setName(String): boolean
        }

        class Admin {
        }

        class Technician {
            - String nif
            - String address
            - String phone
            + getNif(): String
            + getPhone(): String
        }

        class Client {
            - String nif
            - String address
            - String phone
            + getNif(): String
        }
    }

    class ManageUsers {
        - ArrayList<User> users
        + login(String, String): User
        + searchUser(String, String): ArrayList<User>
        + register(User): boolean
        + aproveUser(User, boolean): boolean
        + displayUserList(ArrayList<User>): void
        + displayUserListIndexed(ArrayList<User>): void
        + displayUserListDetailed(ArrayList<User>): void
    }
}

' ========================================
' SERVICES LAYER (TOP-RIGHT)
' ========================================
package "Services Layer" <<Service>> {
    together {
        class Service <<Serializable>> {
            - int code
            - String description
            - String status
            - ArrayList<ServiceAnalysis> analyses
            - float totalValue
            + addAnalysis(ServiceAnalysis): boolean
            + removeAnalysis(String): boolean
        }

        class ServiceAnalysis <<Serializable>> {
            - int code
            - ArrayList<Test> tests
            - String status
            - String finalResult
            + addTest(Test): boolean
            + setFinalResult(String): boolean
            + setStatus(String): void
        }

        class LabAnalysis <<Serializable>> {
            - int code
            - String name
            - String methods
            - float value
            - ArrayList<Test> tests
            + addTest(Test): boolean
            + getName(): String
            + getTests(): ArrayList<Test>
        }

        class Test <<Serializable>> {
            - String designation
            - String referenceValue
            - String measuredValue
            - String unit
            + setMeasuredValue(String): boolean
        }
    }

    together {
        class Certification <<Serializable>> {
            - String nivel
            - String grau
            + getNivel(): String
        }

        class ChemicalComponent <<Serializable>> {
            - int code
            - String name
            - int stockQty
            + changeStockQty(int): boolean
            + getStockQty(): int
        }

        class Supplier <<Serializable>> {
            - int code
            - String name
            - String address
            - String phone
        }

        class MedicalArea <<Serializable>> {
            - int code
            - String designation
            - String family
        }

        class Category <<Serializable>> {
            - int code
            - String name
        }

        class Order <<Serializable>> {
            - int code
            - String status
            - ArrayList<ChemicalComponent> items
            + addItem(ChemicalComponent): void
            + removeItem(ChemicalComponent): void
        }
    }

    class ManageServices {
        - ArrayList<Service> services
        + requestService(Client, Service): boolean
        + assignTechnician(Admin, int, Technician): boolean
        + searchService(String, String): ArrayList<Service>
        + displayServiceList(ArrayList<Service>): void
        + displayServiceListIndexed(ArrayList<Service>): void
    }

    class ManageCatalog {
        - ArrayList<LabAnalysis> analyses
        - ArrayList<ChemicalComponent> components
        - ArrayList<Supplier> suppliers
        - ArrayList<Order> orders
        + displayAnalysisList(ArrayList<LabAnalysis>): void
        + displayTestListIndexed(ArrayList<Test>): void
        + displayComponentListIndexed(ArrayList<ChemicalComponent>): void
        + displaySupplierListIndexed(ArrayList<Supplier>): void
    }
}

' ========================================
' DATA LAYER (BOTTOM-LEFT)
' ========================================
package "Data Layer" <<Data>> {
    together {
        class AppData <<Serializable>> {
            - ArrayList<User> users
            - ArrayList<Service> services
            - ArrayList<LabAnalysis> analyses
            - ArrayList<Category> categories
            - ArrayList<Order> orders
            + setUsers(ArrayList<User>): boolean
            + getUsers(): ArrayList<User>
        }

        class DataStorage {
            - String filePath
            + loadData(AppData): boolean
            + saveData(AppData): AppData
            + fileExists(): boolean
        }

        class CredentialsManager {
            - String filePath
            + saveCredentials(ArrayList<User>): boolean
            + loadCredentials(): ArrayList<String>
        }
    }
}

' ========================================
' APPLICATION LAYER (BOTTOM-RIGHT)
' ========================================
package "Application Layer" <<App>> {
    together {
        class Session {
            - User currentUser
            + setCurrentUser(User): boolean
            + getCurrentUser(): User
            + logout(): boolean
            + isLoggedIn(): boolean
        }

        class ApplicationManager {
            - ManageUsers manageUsers
            - ManageServices manageServices
            - ManageCatalog manageCatalog
            - DataStorage storage
            - Session session
            + startup(): boolean
            + shutdown(): boolean
            + getManageUsers(): ManageUsers
            + getManageCatalog(): ManageCatalog
        }

        class MenuManager {
            - ApplicationManager appManager
            - LogManager logManager
            - SystemInfo systemInfo
            + showMainMenu(): void
            + showAdminMenu(): void
            + showTechnicianMenu(): void
            + handleLogin(): void
            + handleRegister(): void
        }
    }
}

' ========================================
' INHERITANCE RELATIONSHIPS
' ========================================
User <|-- Admin
User <|-- Technician
User <|-- Client

' ========================================
' COMPOSITION (STRONG OWNERSHIP)
' ========================================
Service *-- ServiceAnalysis
ServiceAnalysis *-- Test
LabAnalysis *-- Test
LabAnalysis *-- Certification
Order *-- ChemicalComponent

' ========================================
' AGGREGATION (WEAK OWNERSHIP)
' ========================================
ServiceAnalysis o-- LabAnalysis
ServiceAnalysis o-- Technician
Service o-- Client
Service o-- Technician
Order o-- Supplier
Order o-- Technician
LabAnalysis o-- MedicalArea
LabAnalysis o-- Supplier
LabAnalysis o-- ChemicalComponent

' ========================================
' MANAGEMENT ASSOCIATIONS
' ========================================
ManageUsers --> User
ManageServices --> Service
ManageCatalog --> LabAnalysis
ManageCatalog --> ChemicalComponent
ManageCatalog --> Supplier
ManageCatalog --> Order

' ========================================
' APPLICATION STRUCTURE
' ========================================
ApplicationManager *-- ManageUsers
ApplicationManager *-- ManageServices
ApplicationManager *-- ManageCatalog
ApplicationManager *-- Session
ApplicationManager --> DataStorage

MenuManager --> ApplicationManager
MenuManager --> LogManager
MenuManager --> SystemInfo
MenuManager --> Validator

Session --> User

' ========================================
' DATA LAYER CONNECTIONS
' ========================================
AppData --> User
AppData --> Service
AppData --> LabAnalysis
AppData --> Order
DataStorage ..> AppData
CredentialsManager ..> User

' ========================================
' NOTES
' ========================================
note right of User
  Base class for all users
  Implements Serializable
end note

note right of Service
  Main workflow entity
  Client → Service → Analyses
end note

note right of ManageCatalog
  Central catalog manager
  Uses generic display methods
end note

note right of ApplicationManager
  Core controller
  Manages all layers
end note

note right of AppData
  Data Transfer Object
  Used for persistence
end note

@enduml

' ========== INHERITANCE RELATIONSHIPS ==========
User <|-- Admin : extends
User <|-- Technician : extends
User <|-- Client : extends

' ========== COMPOSITION RELATIONSHIPS ==========
' Strong ownership - lifecycle dependent
Service *-- ServiceAnalysis : contains
ServiceAnalysis *-- Test : owns tests
LabAnalysis *-- Test : defines tests
LabAnalysis *-- Certification : has
Order *-- ChemicalComponent : contains items

' ========== AGGREGATION RELATIONSHIPS ==========
' Weak ownership - shared lifecycle
ServiceAnalysis o-- LabAnalysis : references
ServiceAnalysis o-- Technician : assigned to
ServiceAnalysis o-- Technician : supervised by
Service o-- Client : requested by
Service o-- Technician : assigned to
Order o-- Supplier : from
Order o-- Technician : created by
LabAnalysis o-- MedicalArea : applies to
LabAnalysis o-- Supplier : uses
LabAnalysis o-- ChemicalComponent : requires

' ========== MANAGEMENT ASSOCIATIONS ==========
ManageUsers --> User : manages >
ManageServices --> Service : manages >
ManageCatalog --> LabAnalysis : manages >
ManageCatalog --> ChemicalComponent : manages >
ManageCatalog --> Supplier : manages >
ManageCatalog --> MedicalArea : manages >
ManageCatalog --> Order : manages >
ManageCatalog --> Category : manages >
ManageCatalog --> Test : manages >

' ========== APPLICATION STRUCTURE ==========
ApplicationManager *-- ManageUsers : owns
ApplicationManager *-- ManageServices : owns
ApplicationManager *-- ManageCatalog : owns
ApplicationManager *-- Session : has
ApplicationManager --> DataStorage : uses >

MenuManager --> ApplicationManager : controls >
MenuManager --> LogManager : logs to >
MenuManager --> SystemInfo : tracks with >
MenuManager ..> Validator : validates with 

Session --> User : current user >

' ========== DATA LAYER ==========
AppData --> User : stores
AppData --> Service : stores
AppData --> LabAnalysis : stores
AppData --> Category : stores
AppData --> Test : stores
AppData --> MedicalArea : stores
AppData --> Supplier : stores
AppData --> Order : stores
AppData --> ChemicalComponent : stores

DataStorage ..> AppData : serializes
CredentialsManager ..> User : exports credentials

' ========== NOTES ==========
note right of User
  Base class for all users.
  Implements Serializable for persistence.
  Comparable for sorting by username.
end note

note right of Service
  Main service request entity.
  Client requests services containing
  multiple analyses. Tracks workflow
  from request to completion.
end note

note right of ServiceAnalysis
  Links a LabAnalysis template to
  a specific Service. Contains actual
  test results and technician assignments.
end note

note right of LabAnalysis
  Catalog template for analysis types.
  Defines tests, required components,
  medical areas, and pricing.
end note

note right of ManageCatalog
  Central catalog management.
  Uses generic display methods:
  - displayList<T>()
  - displayListIndexed<T>()
  Generates unique codes for entities.
end note

note right of Validator
  Static utility class.
  Regex-based input validation:
  - Email, phone, username
  - Password strength
  - Numeric values, NIF
  Used throughout MenuManager.
end note

note right of ApplicationManager
  Core application controller.
  Manages all business logic layers.
  Handles data persistence via
  DataStorage and AppData.
end note

note left of AppData
  Data Transfer Object.
  Aggregates all entities for
  serialization. Used for save/load
  operations via DataStorage.
end note

note bottom of Session
  Tracks logged-in user.
  Maintains authentication state
  throughout application lifecycle.
end note

@enduml
